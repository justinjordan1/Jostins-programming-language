class Point {
    var x interger = 0;
    var y interger = 0;

    init : interger(interger startX, interger startY) {
        this.x = startX;
        this.y = startY;
        return 0;
    }

    move : interger(interger dx, interger dy) {
        x = x + dx;
        y = y + dy;
        return x + y;
    }
}

var p object = Point(3, 4);
p.move(10, 20);
return p.x + p.y;
